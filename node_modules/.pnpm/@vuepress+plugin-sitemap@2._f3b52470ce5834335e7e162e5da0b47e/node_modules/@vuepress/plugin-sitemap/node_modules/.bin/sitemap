#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/c/Users/yangl/Desktop/tx7do.github.io/node_modules/.pnpm/sitemap@8.0.3/node_modules/sitemap/node_modules:/mnt/c/Users/yangl/Desktop/tx7do.github.io/node_modules/.pnpm/sitemap@8.0.3/node_modules:/mnt/c/Users/yangl/Desktop/tx7do.github.io/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/c/Users/yangl/Desktop/tx7do.github.io/node_modules/.pnpm/sitemap@8.0.3/node_modules/sitemap/node_modules:/mnt/c/Users/yangl/Desktop/tx7do.github.io/node_modules/.pnpm/sitemap@8.0.3/node_modules:/mnt/c/Users/yangl/Desktop/tx7do.github.io/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../../sitemap@8.0.3/node_modules/sitemap/dist/cli.js" "$@"
else
  exec node  "$basedir/../../../../../../sitemap@8.0.3/node_modules/sitemap/dist/cli.js" "$@"
fi
